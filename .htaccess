Options -Indexes

RewriteEngine On

# Redirection 26.nbarch.com → nbarch.com (301 permanent)
RewriteCond %{HTTP_HOST} ^26\.nbarch\.com$ [NC]
RewriteRule ^(.*)$ https://nbarch.com/$1 [R=301,L]

# Fichiers et dossiers réels → servis directement
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Admin et actions → gérés par leurs propres .htaccess / fichiers
RewriteRule ^nbadmin(/|$) - [L]
RewriteRule ^actions/ - [L]

# /realisations/nom-du-projet  → projet.php
RewriteRule ^([a-z0-9-]+)/([a-z0-9-]+)/?$  projet.php?cat=$1&slug=$2 [L,QSA]

# /realisations                → categorie.php
RewriteRule ^([a-z0-9-]+)/?$   categorie.php?slug=$1 [L,QSA]

# Protection dossier uploads (pas d'exécution PHP)
<FilesMatch "\.(php|php[0-9]|phtml|phar)$">
    <If "%{REQUEST_URI} =~ m#/uploads/#">
        Require all denied
    </If>
</FilesMatch>
